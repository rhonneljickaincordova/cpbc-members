rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Members, attendance, and payments are publicly readable (for member lookup)
    match /members/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /attendance/{document} {
      allow read: if true;
      // Authenticated users get full write access
      allow write: if request.auth != null;
      // Unauthenticated users can create events (auto-schedule) and update attendees only
      allow create: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees']);
    }

    match /payments/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else requires auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
